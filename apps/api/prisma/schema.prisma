// Klarify Prisma schema — mirrors apps/api/db/migrations/001_init.sql.
// RLS lives in 002_rls.sql; Prisma doesn't manage it. The API must run every
// query under a transaction with `app.current_user_id` / `app.current_org_id`
// session variables set (see apps/api/src/db.ts).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // `native` covers local dev (macOS / Linux dev containers).
  // `rhel-openssl-3.0.x` covers Netlify Functions / AWS Lambda runtime
  //   (Amazon Linux 2023). Without it the function throws at runtime:
  //     "Prisma Client could not locate the Query Engine for runtime
  //      'rhel-openssl-3.0.x'"
  // `debian-openssl-3.0.x` covers Vercel Serverless and most Docker images.
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  // Runtime queries — use the Supavisor transaction pooler. Required for
  // serverless deployments (Netlify Functions) where IPv6 isn't routable.
  url        = env("DATABASE_URL")
  // Migrations + introspection — bypass the pooler. pgbouncer transaction
  // mode doesn't support prepared statements or DDL, so `prisma migrate`
  // and `prisma db push` must use the direct connection. Set DIRECT_URL
  // locally; CI/CD that doesn't run migrations can omit it.
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, vector]
}

// =============================================================================
// Users & Orgs
// =============================================================================
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String?
  avatar    String?
  plan      String   @default("free")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  ownedOrgs          Organisation[]        @relation("OrgOwner")
  memberships        OrgMember[]
  profile            UserProfile?
  conversations      Conversation[]
  generatedDocs      GeneratedDocument[]
  uploadedDocs       UploadedDocument[]
  ownedRoadmapTasks  RoadmapTask[]

  @@map("users")
}

model Organisation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  ownerId   String   @map("owner_id") @db.Uuid
  plan      String   @default("free")
  seatsUsed Int      @default(1) @map("seats_used")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  owner                  User                    @relation("OrgOwner", fields: [ownerId], references: [id])
  members                OrgMember[]
  readinessScores        ReadinessScore[]
  roadmapTasks           RoadmapTask[]
  generatedDocs          GeneratedDocument[]
  uploadedDocs           UploadedDocument[]
  conversations          Conversation[]
  regulatorContacts      RegulatorContact[]
  regulatorInteractions  RegulatorInteraction[]
  aripApplication        AripApplication?
  complianceEvents       ComplianceEvent[]
  subscriptions          Subscription[]

  @@index([ownerId])
  @@map("organisations")
}

model OrgMember {
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@index([userId])
  @@map("org_members")
}

model UserProfile {
  userId                  String   @id @map("user_id") @db.Uuid
  productTypes            String[] @default([]) @map("product_types")
  targetMarkets           String[] @default([]) @map("target_markets")
  stage                   String?
  teamSize                Int?     @map("team_size")
  hasComplianceOfficer    Boolean  @default(false) @map("has_compliance_officer")
  existingInfrastructure  String[] @default([]) @map("existing_infrastructure")
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// =============================================================================
// Compliance
// =============================================================================
model ReadinessScore {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                    String   @map("org_id") @db.Uuid
  totalScore               Int      @map("total_score")
  corporateStructure       Int      @map("corporate_structure")
  capitalLicensing         Int      @map("capital_licensing")
  kycInfrastructure        Int      @map("kyc_infrastructure")
  amlCftProgramme          Int      @map("aml_cft_programme")
  transactionMonitoring    Int      @map("transaction_monitoring")
  regulatoryReporting      Int      @map("regulatory_reporting")
  regulatoryRelationships  Int      @map("regulatory_relationships")
  productClassification    Int      @map("product_classification")
  calculatedAt             DateTime @default(now()) @map("calculated_at") @db.Timestamptz()
  snapshot                 Json     @default("{}")

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, calculatedAt(sort: Desc)])
  @@map("readiness_scores")
}

model RoadmapTask {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  phase           Int
  title           String
  description     String?
  regulatoryBasis String?   @map("regulatory_basis")
  status          String    @default("not_started")
  ownerUserId     String?   @map("owner_user_id") @db.Uuid
  dueDate         DateTime? @map("due_date") @db.Date
  templateId      String?   @map("template_id")
  indicatorKey    String?   @map("indicator_key")
  isLocked        Boolean   @default(false) @map("is_locked")
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  org   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner User?        @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([orgId, phase])
  @@index([ownerUserId])
  @@map("roadmap_tasks")
}

// =============================================================================
// Documents
// =============================================================================
model GeneratedDocument {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  templateType  String   @map("template_type")
  title         String
  content       Json     @default("{}")
  version       Int      @default(1)
  s3Key         String?  @map("s3_key")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@map("generated_documents")
}

model UploadedDocument {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  filename       String
  fileType       String?   @map("file_type")
  s3Key          String    @map("s3_key")
  analysisResult Json?     @map("analysis_result")
  urgencyLevel   String?   @map("urgency_level")
  actionItems    Json?     @map("action_items")
  uploadedAt     DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz()
  analysedAt     DateTime? @map("analysed_at") @db.Timestamptz()

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@map("uploaded_documents")
}

// =============================================================================
// AI conversations
// =============================================================================
model Conversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  title     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([orgId])
  @@map("conversations")
}

model Message {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId  String   @map("conversation_id") @db.Uuid
  role            String
  content         String
  citations       Json     @default("[]")
  modelUsed       String?  @map("model_used")
  tokensUsed      Int?     @map("tokens_used")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// =============================================================================
// Regulators
// =============================================================================
model Regulator {
  code              String   @id
  name              String
  mandate           String
  website           String?
  portal            String?
  email             String?
  phone             String?
  address           String?
  jurisdictionTags  String[] @default([]) @map("jurisdiction_tags")

  contacts     RegulatorContact[]
  interactions RegulatorInteraction[]

  @@map("regulators")
}

model RegulatorContact {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  regulatorCode   String   @map("regulator_code")
  contactName     String?  @map("contact_name")
  contactEmail    String?  @map("contact_email")
  contactPhone    String?  @map("contact_phone")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  regulator Regulator    @relation(fields: [regulatorCode], references: [code])

  @@index([orgId])
  @@map("regulator_contacts")
}

model RegulatorInteraction {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  regulatorCode       String    @map("regulator_code")
  interactionType     String    @map("interaction_type")
  subject             String
  outcome             String?
  followUpRequired    Boolean   @default(false) @map("follow_up_required")
  followUpDate        DateTime? @map("follow_up_date") @db.Date
  occurredAt          DateTime  @default(now()) @map("occurred_at") @db.Timestamptz()
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  regulator Regulator    @relation(fields: [regulatorCode], references: [code])

  @@index([orgId, occurredAt(sort: Desc)])
  @@map("regulator_interactions")
}

// =============================================================================
// ARIP
// =============================================================================
model AripApplication {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String    @unique @map("org_id") @db.Uuid
  licenceType     String    @map("licence_type")
  currentStage    String    @default("pre_screening") @map("current_stage")
  aipIssuedDate   DateTime? @map("aip_issued_date") @db.Date
  aipExpiryDate   DateTime? @map("aip_expiry_date") @db.Date
  notes           Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("arip_applications")
}

// =============================================================================
// Calendar & Subscriptions
// =============================================================================
model ComplianceEvent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  eventType    String    @map("event_type")
  title        String
  description  String?
  dueDate      DateTime  @map("due_date") @db.Timestamptz()
  recurrence   String?
  isComplete   Boolean   @default(false) @map("is_complete")
  completedAt  DateTime? @map("completed_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, dueDate])
  @@map("compliance_events")
}

model Subscription {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId              String    @map("org_id") @db.Uuid
  plan               String
  billingCycle       String    @map("billing_cycle")
  flutterwaveSubId   String?   @map("flutterwave_sub_id")
  stripeSubId        String?   @map("stripe_sub_id")
  status             String    @default("active")
  currentPeriodEnd   DateTime? @map("current_period_end") @db.Timestamptz()
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// =============================================================================
// Regulatory corpus (pgvector — Section 11)
// =============================================================================
model RegulatoryCorpus {
  id                String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceDocument    String                       @map("source_document")
  jurisdiction      String
  sectionReference  String?                      @map("section_reference")
  content           String
  // Prisma 5+ supports the Unsupported type for vector columns.
  embedding         Unsupported("vector(1024)")?
  metadata          Json                         @default("{}")
  createdAt         DateTime                     @default(now()) @map("created_at") @db.Timestamptz()

  @@index([jurisdiction])
  @@index([sourceDocument])
  @@map("regulatory_corpus")
}
