{
  "name": "@klarify/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Klarify backend — Node.js + Hono",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "tsx src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "deploy:fly": "cd ../.. && fly deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-textract": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.8.0",
    "@klarify/ai": "workspace:*",
    "@klarify/config": "workspace:*",
    "@klarify/core": "workspace:*",
    "@klarify/email": "workspace:*",
    "@prisma/client": "^5.20.0",
    "@types/node": "^20.14.0",
    "docx": "^9.0.0",
    "hono": "^4.6.0",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "pdf-parse": "^1.1.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.5",
    "vitest": "^2.1.0"
  }
}
