{
  "name": "klarify",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Klarify Africa — AI-powered regulatory compliance and advisory platform",
  "author": "Chimezie Chuta <chimeziechuta@gmail.com>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@klarify/config": "workspace:*",
    "@netlify/plugin-nextjs": "^5.15.11",
    "eslint": "^9.10.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
