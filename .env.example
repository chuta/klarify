# =============================================================================
# Klarify — Environment Variables
# =============================================================================
# Copy this file to .env (root) or .env.local (per app) and fill values.
# Do NOT commit .env / .env.local — they are gitignored.
# Source: CLAUDE.md Section 15, plus Supabase-specific extensions.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Direct connection (use for Prisma migrations / db:push):
#   postgresql://postgres:[PASSWORD]@db.ladnmszfzbfhthcmjuww.supabase.co:5432/postgres
# Pooled connection (use for the API runtime — port 6543, pgbouncer):
#   postgresql://postgres.ladnmszfzbfhthcmjuww:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Grab both from Supabase Dashboard → Project Settings → Database → Connection string.
DATABASE_URL=
DIRECT_URL=

# Supabase project (URL is public; service role key is server-only — never ship to client)
SUPABASE_URL=https://ladnmszfzbfhthcmjuww.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT signing secret — Supabase Dashboard → Settings → API → JWT Settings → JWT Secret.
# Used by apps/api to verify Bearer tokens from web/mobile clients.
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Required in all environments
# -----------------------------------------------------------------------------
REDIS_URL=
JWT_SECRET=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# AI — model assignments per task type (CLAUDE.md §15)
# -----------------------------------------------------------------------------
ANTHROPIC_MODEL_ADVISORY=claude-sonnet-4-5    # FounderCounsel responses
ANTHROPIC_MODEL_ARCH=claude-opus-4            # Complex reasoning tasks
ANTHROPIC_MODEL_SIMPLE=claude-haiku-4-5       # Simple factual queries
VOYAGE_API_KEY=                               # Embeddings (voyage-law-2, 1024 dims)

# -----------------------------------------------------------------------------
# Storage (S3 / Cloudflare R2)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend preferred, SendGrid fallback)
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# OCR (AWS Textract — regulatory letter image uploads)
# -----------------------------------------------------------------------------
AWS_TEXTRACT_REGION=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://ladnmszfzbfhthcmjuww.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Expo-exposed (apps/mobile). Identical values to the NEXT_PUBLIC_* ones above.
EXPO_PUBLIC_SUPABASE_URL=https://ladnmszfzbfhthcmjuww.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
